<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvHello"
            android:textAppearance="?attr/textAppearanceHeadline5"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="@string/controller_dashboard_subtitle"
            android:textAppearance="?attr/textAppearanceBody1"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardToday"
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout android:padding="20dp" android:orientation="vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="@string/menu_today" android:textSize="20sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="@string/menu_today_desc"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAll"
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout android:padding="20dp" android:orientation="vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="@string/menu_all" android:textSize="20sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="@string/menu_all_desc"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDashboard"
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout android:padding="20dp" android:orientation="vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="@string/menu_dashboard" android:textSize="20sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="@string/menu_dashboard_desc"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSendInfo"
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout android:padding="20dp" android:orientation="vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="@string/menu_send_info" android:textSize="20sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="@string/menu_send_info_desc"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMessages"
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_marginBottom="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout android:padding="20dp" android:orientation="vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="@string/menu_messages" android:textSize="20sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="@string/menu_messages_desc"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:text="@string/logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>
